{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "noEmit": true,
    "esModuleInterop": true,
    "lib": [
      "ES2022"
    ]
  },
  "include": [
    "plugins/**/*.ts"
  ]
}
